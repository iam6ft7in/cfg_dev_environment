# =============================================================================
# ~/.gitignore_global — Global gitignore template
# Generated by phase_05_gitignore.ps1
# =============================================================================

# -----------------------------------------------------------------------------
# Windows OS files
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# VS Code (keep extensions.json tracked; ignore user-specific files)
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/*.code-workspace
.vscode/launch.json
.vscode/.history/

# -----------------------------------------------------------------------------
# JetBrains IDEs
# -----------------------------------------------------------------------------
.idea/
*.iml

# -----------------------------------------------------------------------------
# General temp / editor artifacts
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo
.DS_Store

# -----------------------------------------------------------------------------
# Environment files / secrets — never commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.*
credentials.*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Node / JavaScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*

# -----------------------------------------------------------------------------
# Archives (avoid accidentally committing large binary blobs)
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.rar
